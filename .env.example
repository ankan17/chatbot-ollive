# ── Datastores ────────────────────────────────────────────────────────────────
# Host-facing defaults (for local dev and the E2E runner on the host).
# docker compose overrides these to the container-internal hostnames:
#   DATABASE_URL → postgres://ollive:ollive@postgres:5432/ollive
#   REDIS_URL    → redis://redis:6379
DATABASE_URL=postgres://ollive:ollive@localhost:5432/ollive
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# AUTH_MODE=dev  → auto-authenticates as the seeded demo user (no Google creds needed)
# AUTH_MODE=google → real Google OAuth (requires GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET)
AUTH_MODE=dev
GOOGLE_CLIENT_ID=                   # required only when AUTH_MODE=google
GOOGLE_CLIENT_SECRET=               # required only when AUTH_MODE=google (secret — never commit a real value)
# GOOGLE_REDIRECT_URI=              # optional override; default: ${API_BASE_URL}/auth/google/callback
JWT_SECRET=dev-jwt-secret-change-me # signs the session cookie (SE3). Change for any non-local use.

# ── Ingestion (service-to-service) ───────────────────────────────────────────
INGESTION_API_KEY=dev-ingestion-key # SDK sends `Authorization: Bearer <key>` to /v1/logs (AU5/SE2)

# ── LLM provider ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY is required for live chat generation.
# The stack starts with the placeholder below — only live LLM calls will fail.
# Replace with a real key to enable chat: https://aistudio.google.com/apikey
GEMINI_API_KEY=set-a-real-key-for-live-chat
DEFAULT_MODEL=gemini-2.5-flash      # default model for new conversations (A10)
CONTEXT_TOKEN_BUDGET=4000           # max prompt tokens for context window (A3/BE5)

# ── Web / CORS ────────────────────────────────────────────────────────────────
# The SPA origin used by the API's CORS config (BE8/SE4).
# With the nginx reverse proxy (compose default) the browser uses a single origin,
# so this is informational for the proxied path.
WEB_ORIGIN=http://localhost:8080

# ── Guest trial ───────────────────────────────────────────────────────────────
GUEST_MESSAGE_LIMIT=2               # anonymous messages allowed before sign-in (A11/FR15)
GUEST_SESSION_TTL=86400             # guest session / Redis counter TTL in seconds (AU7)

# ── Privacy ───────────────────────────────────────────────────────────────────
PII_REDACTION=pattern               # off | pattern | llm — telemetry PII scrubbing (SDK9/SE6)

# ── API tunables (Plan 3 — defaults applied if omitted) ──────────────────────
PORT=4000
INGESTION_STREAM_MAXLEN=100000      # approximate cap on the inference-logs Redis stream (IN2)

# ── Ingestion worker tunables (Plan 3 — defaults applied if omitted) ─────────
WORKER_CONSUMER_NAME=worker-1
WORKER_BATCH_SIZE=50
WORKER_BLOCK_MS=5000
WORKER_MAX_DELIVERIES=3
WORKER_CLAIM_IDLE_MS=30000
