{
  "name": "ollive",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run --no-file-parallelism",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "db:generate": "pnpm --filter @ollive/db generate",
    "db:migrate": "pnpm --filter @ollive/db migrate",
    "start:api": "pnpm --filter @ollive/api start",
    "start:worker": "pnpm --filter @ollive/ingestion-worker start",
    "dev:api": "pnpm --filter @ollive/api dev",
    "dev:worker": "pnpm --filter @ollive/ingestion-worker dev",
    "e2e": "OLLIVE_E2E=1 vitest run --project e2e",
    "e2e:compose": "scripts/e2e-compose.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^3.0.0"
  }
}
